generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Site {
  id         String    @id @default(cuid())
  name       String
  url        String    @unique
  apiKey     String    @unique @default(cuid())
  categories Json      @default("[]")
  logoUrl    String?
  faviconUrl String?
  menuConfig Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  articles   Article[]
}

model Article {
  id              String    @id @default(cuid())
  siteId          String
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  content         String    @default("")
  metaTitle       String?
  metaDescription String?
  category        String?
  status          String    @default("draft")
  imageUrl        String?
  publishedAt     DateTime?
  subject         String?
  keyword         String?
  tone            String?
  language        String    @default("FR")
  wordCount       Int?
  generationLog   Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([siteId, slug])
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String?
  version     String?
  css         String
  active      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Category {
  id              String   @id @default(cuid())
  label           String   @unique
  slug            String   @unique
  metaTitle       String?
  metaDescription String?
  seoIntro        String?
  seoH2           String?
  seoCol1Title    String?
  seoCol1Body     String?
  seoCol2Title    String?
  seoCol2Body     String?
  seoFaq          Json?
  fromSetup       Boolean  @default(false)
  description     String?
  heroImage       String?
  bullets         Json?
  createdAt       DateTime @default(now())
}
