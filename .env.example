# SQLite database path (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Anthropic API key — used by Pilot to generate articles
ANTHROPIC_API_KEY="sk-ant-..."

# Unsplash API key — used to fetch hero images during setup
UNSPLASH_ACCESS_KEY="your_unsplash_access_key"

# Admin credentials
ADMIN_EMAIL="admin@votredomaine.com"
ADMIN_PASSWORD="motdepassefort"

# JWT secret — minimum 32 characters, unique per installation
AUTH_SECRET="changez_ceci_32_caracteres_minimum"

# Public URL of this install (used as fallback if the Site record has no URL)
NEXT_PUBLIC_APP_URL="https://votredomaine.com"
